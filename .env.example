AI_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
CEREBRAS_API_KEY=your_cerebras_api_key

# Cloudflare R2 settings (used with --r2)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

WP_URL=https://your-wordpress-site.com
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=your_wordpress_application_password

WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret

GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-4-scout-17b-16e-instruct

# Cerebras used only for text fallback
CEREBRAS_MODEL=llama3.1-8b

REQUEST_TIMEOUT=60
REQUEST_DELAY_SECONDS=2
AI_REQUEST_DELAY_SECONDS=3

CONTENT_LANGUAGE=de
# Optional overrides:
# DOWNLOAD_DIR=./data/downloads
# LOG_DIR=./logs
# CATEGORY_MAP_PATH=./data/category_map.json
